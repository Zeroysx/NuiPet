    "sleep": "Dedicated v0.2.3 prone sleep row with a small attached Z cue and a longer closed-eye hold.",
    "fall": "Physics-only generated 16-frame airborne falling row with stronger weightless imbalance during fast vertical release.",
    "fall_land": "Physics-only generated 16-frame impact row played only after the pet reaches the bottom.",
    "fall_getup": "Physics-only generated 16-frame prone-to-standing get-up row played after fall_land.",
    "idle_alt": "Former wake row; visually closer to a second idle action.",
    "walk": "Light jog row with small per-frame motionX offsets to reduce stiff in-place movement.",
    "think": "Former blink row; visually closer to thinking with a longer closed-eye hold.",
    "idle_long": "Former breathe row; retained for compatibility but removed from menu and idle pools.",
    "nod": "Former stretch row; blank trailing frames removed.",
    "idle_blink": "Alias to the single retained thinking action."
  },
