{
  "$schema": "https://raw.githubusercontent.com/neutralinojs/neutralinojs/main/schemas/neutralino.config.schema.json",
  "applicationId": "com.zeroysx.nuipet",
  "version": "0.2.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/web/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "dataLocation": "system",
  "storageLocation": "system",
  "applicationName": "NuiPet",
  "author": "Zeroysx",
  "description": "A lightweight desktop pet based on Luyi Nui.",
  "applicationIcon": "web/assets/icons/app-icon.png",
  "logging": {
    "enabled": false,
    "writeToLogFile": false
  },
  "nativeAllowList": [
    "app.*",
    "events.*",
    "os.setTray",
    "storage.*",
    "window.*"
  ],
  "modes": {
    "window": {
      "title": "NuiPet",
      "width": 384,
      "height": 416,
      "minWidth": 192,
      "minHeight": 208,
      "fullScreen": false,
      "alwaysOnTop": true,
      "enableInspector": false,
      "borderless": true,
      "skipTaskbar": true,
      "maximize": false,
      "hidden": false,
      "resizable": false,
      "useSavedState": false,
      "injectClientLibrary": true,
      "exitProcessOnClose": true,
      "transparent": true
    }
  },
  "cli": {
    "binaryName": "NuiPet",
    "resourcesPath": "/web/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "/neutralino.js",
    "binaryVersion": "6.7.0",
    "clientVersion": "6.7.0"
  }
}
